#!/bin/bash
set -euo pipefail

# Manage victoria-metrics service
#
# Usage: manage <command>
#
# Commands:
#   install    Install/configure victoria-metrics
#   status     Show running status and which hosts are sending data
#   uninstall  Remove victoria-metrics
#
# Required env vars for install (set via inventory hostvars, passed by runcible):
#   VICTORIA_METRICS_USERNAME   - HTTP basic auth username
#   VICTORIA_METRICS_PASSWORD   - HTTP basic auth password
#   VICTORIA_METRICS_RETENTION  - retention period (e.g. 3d, 1, 12) default: 1 month

# Decode rexer base64-encoded LC_* environment variables in place
_decode_rexer_env() {
    for var in $(compgen -v LC_); do
        local val="${!var}"
        if [[ "$val" == _b64:* ]]; then
            export "$var"="$(echo "${val#_b64:}" | base64 -d)"
        fi
    done
}
_decode_rexer_env

_check_service() {
    local svc="$1"
    local retries=10
    while ! systemctl is-active --quiet "$svc"; do
        retries=$((retries - 1))
        if [[ $retries -eq 0 ]]; then
            echo "ERROR: $svc failed to start"
            systemctl status "$svc" --no-pager || true
            journalctl -u "$svc" -n 20 --no-pager
            exit 1
        fi
        sleep 1
    done
    sleep 2
    if ! systemctl is-active --quiet "$svc"; then
        echo "ERROR: $svc started but then crashed"
        systemctl status "$svc" --no-pager || true
        journalctl -u "$svc" -n 20 --no-pager
        exit 1
    fi
}

_wait_for_victoria_metrics() {
    local auth="$1"
    local retries=10
    while ! curl -s -u "$auth" "http://127.0.0.1:8428/health" > /dev/null 2>&1; do
        retries=$((retries - 1))
        if [[ $retries -eq 0 ]]; then
            echo "ERROR: victoria-metrics HTTP endpoint not reachable"
            systemctl status victoria-metrics --no-pager || true
            journalctl -u victoria-metrics -n 20 --no-pager
            exit 1
        fi
        sleep 1
    done
}

install() {
    local USERNAME="${LC_VICTORIA_METRICS_USERNAME:?LC_VICTORIA_METRICS_USERNAME must be set}"
    local PASSWORD="${LC_VICTORIA_METRICS_PASSWORD:?LC_VICTORIA_METRICS_PASSWORD must be set}"
    local RETENTION="${LC_VICTORIA_METRICS_RETENTION:-1}"

    echo "Installing victoria-metrics..."
    DEBIAN_FRONTEND=noninteractive apt-get install -y -o Dpkg::Options::="--force-confold" victoria-metrics

    echo "Configuring victoria-metrics..."
    cat > /etc/victoria-metrics/victoria-metrics.env <<EOF
LISTEN_ADDR=:8428
VM_HTTP_USERNAME=${USERNAME}
RETENTION_PERIOD=${RETENTION}
EOF

    echo -n "${PASSWORD}" > /etc/victoria-metrics/http-password
    chmod 640 /etc/victoria-metrics/http-password
    chown victoria-metrics:victoria-metrics /etc/victoria-metrics/http-password

    echo "Restarting victoria-metrics..."
    systemctl daemon-reload
    systemctl restart victoria-metrics

    echo "Verifying victoria-metrics is running..."
    _check_service victoria-metrics
    _wait_for_victoria_metrics "${USERNAME}:${PASSWORD}"

    echo "Verifying auth..."
    if ! curl -sf -u "${USERNAME}:${PASSWORD}" "http://127.0.0.1:8428/health" > /dev/null; then
        echo "ERROR: auth verification failed"
        exit 1
    fi
    echo "Auth verified."

    echo "Done."
}

status() {
    local env_file="/etc/victoria-metrics/victoria-metrics.env"
    local pw_file="/etc/victoria-metrics/http-password"

    if [[ ! -f "$env_file" ]] || [[ ! -f "$pw_file" ]]; then
        echo "ERROR: victoria-metrics config not found — is it installed?"
        exit 1
    fi

    set -a; source "$env_file"; set +a
    local password
    password=$(cat "$pw_file")
    local auth="${VM_HTTP_USERNAME}:${password}"
    local base="http://127.0.0.1:8428"

    if ! curl -sf -u "$auth" "${base}/health" > /dev/null 2>&1; then
        echo "victoria-metrics: NOT RUNNING"
        systemctl status victoria-metrics --no-pager || true
        exit 1
    fi
    echo "victoria-metrics: running"

    local result
    result=$(curl -sf -u "$auth" "${base}/api/v1/label/host/values" 2>/dev/null) || {
        echo "ERROR: could not query metrics API"
        exit 1
    }

    local hosts
    hosts=$(echo "$result" | python3 -c "import json,sys; [print(h) for h in json.load(sys.stdin).get('data',[])]" 2>/dev/null | sort)

    if [[ -z "$hosts" ]]; then
        echo "No hosts sending data yet"
    else
        echo "Receiving data from:"
        while IFS= read -r host; do
            echo "  $host"
        done <<< "$hosts"
    fi
}

uninstall() {
    echo "Removing victoria-metrics..."
    systemctl stop victoria-metrics || true
    apt-get remove -y victoria-metrics || true
    echo "Done."
}

case "${1:-}" in
    install)   install ;;
    status)    status ;;
    uninstall) uninstall ;;
    *)
        echo "Usage: manage <install|status|uninstall>"
        exit 1
        ;;
esac
